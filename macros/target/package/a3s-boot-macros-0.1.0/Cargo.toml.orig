[package]
name = "a3s-boot-macros"
version = "0.1.0"
edition = "2021"
authors = ["A3S Lab"]
license = "MIT"
description = "Attribute macros for a3s-boot"
repository = "https://github.com/A3S-Lab/Boot"
documentation = "https://docs.rs/a3s-boot"
keywords = ["web", "framework", "macro", "nest", "adapter"]
categories = ["web-programming", "asynchronous"]

[lib]
proc-macro = true

[dependencies]
proc-macro2 = "1"
quote = "1"
syn = { version = "2", features = ["full"] }
